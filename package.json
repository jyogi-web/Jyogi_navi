{
  "name": "jyogi-navi",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start": "concurrently --kill-others-on-fail \"pnpm infra:up\" \"turbo run dev\"",
    "infra:up": "docker compose -f infra/dify/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/dify/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "concurrently": "^9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
