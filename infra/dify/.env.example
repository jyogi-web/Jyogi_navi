# =====================================
# Dify 環境変数テンプレート
# =====================================
# 編集手順：
# 1. このファイルを .env にコピー
# 2. 各キーを実際の値に置き換え
# 3. infra/dify で `docker-compose up -d` で起動
# 
# cp .env.example .env
# docker-compose up -d

# =====================================
# Basic Dify Settings
# =====================================

# Dify's SECRET_KEY (ランダムな長い文字列を生成)
# 生成コマンド: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# デプロイ環境 (docker, kubernetes, manual)
DEPLOY_ENV=docker

# =====================================
# Supabase (Dify内部DB: PostgreSQL)
# =====================================
# Supabase プロジェクトから取得:
# - Settings > Database > ConnectionString (Psycopg)
# direct host の既定値です。Docker で到達しない場合は下の Pooler 例へ切替してください。

SUPABASE_DB_HOST=db.xxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password
SUPABASE_DB_NAME=postgres

# Pooler を使う場合の例（direct host が到達しないとき）
# SUPABASE_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_USER=postgres.xxxxxxxxxxxxx
# SUPABASE_DB_PASSWORD=your-supabase-db-password
# SUPABASE_DB_NAME=postgres

# Supabase API URL (不使用・参考用)
# SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# =====================================
# Upstash Redis (Cache & Task Queue)
# =====================================
# Upstash コンソール > Database > Redis > Details から取得
# Redis URL Format: rediss://username:password@host:port (Upstash は通常 TLS 必須)
# 空の場合は docker-compose がローカルRedis(dify-redis)へフォールバック

UPSTASH_REDIS_URL=
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_USERNAME=default
UPSTASH_REDIS_PASSWORD=
UPSTASH_REDIS_USE_SSL=true

# ローカルRedis用（docker-compose内）（上記を使わない場合）
# UPSTASH_REDIS_URL=redis://:dify@dify-redis:6379
# $chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.~".ToCharArray()-join (1..32 | ForEach-Object { $chars[(Get-Random -Maximum $chars.Length)] })
REDIS_PASSWORD=please-set-a-strong-random-secret

# =====================================
# TiDB Serverless (Vector DB)
# =====================================
# TiDB Cloud コンソール > Database Connections から取得

TIDB_HOST=gateway01.us-west-2.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-tidb-username
TIDB_PASSWORD=your-tidb-password
TIDB_DATABASE=dify

# (オプション) TiDB SSL接続
# TIDB_SSL_MODE=require

# =====================================
# Gemini API (LLM & Embedding)
# =====================================
# Google Cloud Console でプロジェクト作成 > API キー取得
# Gemini API Reference: https://ai.google.dev/docs

GOOGLE_API_KEY=AIzaSy...(your-gemini-api-key)

# 使用するEmbedding モデル (Gemini埋め込み)
EMBEDDING_MODEL=models/embedding-001

# =====================================
# Dify API Keys (内部認証)
# =====================================
# チャットUI から API 呼び出し時に使用
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"

DIFY_API_SECRET_KEY=your-dify-api-secret-key

# =====================================
# Dify UI URLs
# =====================================
# Dify Web のホスト公開ポート（競合時は変更）
DIFY_WEB_PORT=3101
PLUGIN_DAEMON_URL=http://dify-plugin-daemon:5002
PLUGIN_DAEMON_PORT=5002
PLUGIN_DAEMON_KEY=please-set-a-strong-random-secret
PLUGIN_DIFY_INNER_API_URL=http://dify-api:5001
PLUGIN_DIFY_INNER_API_KEY=please-set-a-strong-random-secret
PLUGIN_DEBUGGING_HOST=0.0.0.0
PLUGIN_DEBUGGING_PORT=5003
# Security-first default: keep remote install debug local-only
# Empty means PLUGIN_REMOTE_INSTALL_HOST is unset and app default is used.
EXPOSE_PLUGIN_DEBUGGING_HOST=
EXPOSE_PLUGIN_DEBUGGING_PORT=5003

# Plugin daemon DB (Supabase transaction pooler(6543) だと起動失敗する場合がある)
# 既定は同一ホストの 5432。必要なら direct host に変更
DB_PLUGIN_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PLUGIN_PORT=5432
DB_PLUGIN_USER=postgres.your-project-ref
DB_PLUGIN_PASSWORD=your-db-password
DB_PLUGIN_DATABASE=dify_plugin

# ローカル開発の場合
DIFY_API_URL=http://127.0.0.1:5001
DIFY_APP_URL=http://127.0.0.1:3101

# 本番環境（Cloudflare Tunnel など）の場合
# DIFY_API_URL=https://dify.yourdomain.com/api
# DIFY_APP_URL=https://dify.yourdomain.com

# =====================================
# CORS Settings
# =====================================
# Next.js チャットUI からのリクエストを許可（* はローカル開発時のみ使用）
CORS_ORIGINS=https://yourfrontend.domain,https://admin.yourfrontend.domain

# ローカル開発時の例
# CORS_ORIGINS=http://127.0.0.1:3101

# 本番環境では必ずフロントエンドの実オリジンを設定
# 例: CORS_ORIGINS=https://yourfrontend.domain,https://admin.yourfrontend.domain

# =====================================
# File Storage
# =====================================
# ファイルアップロード方式 (local / s3 / azure）
STORAGE_TYPE=local

# Difyのローカルストレージ参照先（コンテナ内パス）
# 永続化実体は docker-compose の named volume(dify-storage)で管理
STORAGE_LOCAL_PATH=/app/storage
OPENDAL_FS_ROOT=/app/storage

# ファイルアップロードサイズ制限 (MB)
UPLOAD_FILE_SIZE_LIMIT=100

# =====================================
# Optional: 拡張機能
# =====================================

# OpenAI API キー (Gemini以外も利用する場合)
# OPENAI_API_KEY=sk-...

# Slack Bot Token (Slack連携の場合・P2以降)
# SLACK_BOT_TOKEN=xoxb-...

# SendGrid API Key (メール送信の場合・P2以降)
# SENDGRID_API_KEY=SG...

# =====================================
# Session & Security
# =====================================
# セッションタイムアウト (秒)
SESSION_TIMEOUT=86400

# HTTPS強制 (本番環境のみ)
FORCE_HTTPS=false

# =====================================
# Sandbox / SSRF Proxy
# =====================================
# Code実行系（Workflow/Plugin）で使用
SANDBOX_API_KEY=please-set-a-strong-random-secret
SANDBOX_GIN_MODE=release
SANDBOX_WORKER_TIMEOUT=15
SANDBOX_ENABLE_NETWORK=true

# =====================================
# 運用向けメモ
# =====================================
# 
# 【初回セットアップ】
# 1. Supabase プロジェクト作成 → DB接続情報を取得
# 2. TiDB Serverless クラスター作成 → DB接続情報を取得
# 3. Upstash Redis プロジェクト作成 →接続URL を取得
# 4. Google Cloud API キー取得（Gemini）
# 5. .env.example → .env にコピー＆編集
# 6. `docker-compose up -d` で起動
# 7. http://127.0.0.1:3101 へアクセス
#
# 【トラブルシューティング】
# - Dify API起動しない: SUPABASE DB接続確認
# - ベクトル検索エラー: TiDB接続確認
# - LLM応答なし: GOOGLE_API_KEY確認
# - Redis接続エラー: UPSTASH_REDIS_URL または REDIS_PASSWORD確認
#
# 【本番環境への移行】
# - Cloudflare Tunnel で自宅PC公開
# - セッション長期化 (86400 → 604800)
# - FORCE_HTTPS=true に設定
# - CORS_ORIGINS を制限（* はローカル開発時のみ）
# - UPSTASH_REDIS_URL を設定し、ローカルRedis(profile: local)を使わない
#
