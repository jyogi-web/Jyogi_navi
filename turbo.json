{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "openapi:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["coverage/**"]
    },
    "openapi:export": {
      "inputs": ["main.py", "routers/**", "models/**"],
      "outputs": ["openapi.json"]
    },
    "openapi:generate": {
      "dependsOn": ["api#openapi:export"],
      "inputs": ["../api/openapi.json", "openapi-ts.config.ts"],
      "outputs": ["src/client/**"]
    }
  }
}
