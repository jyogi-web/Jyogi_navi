# TiDB Serverless (MySQL互換)
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
# SSL/TLS CA 証明書のパス（TiDB Serverless 接続時は必須）
# macOS/Linux: TIDB_SSL_CA=/etc/ssl/cert.pem
# Windows    : python -c "import certifi; print(certifi.where())" の出力を使用
#              例) TIDB_SSL_CA=C:/Python311/lib/site-packages/certifi/cacert.pem
# ローカル開発（TiDB なし）: 空のままでOK
# ※ パスが存在しない場合はシステムデフォルト CA にフォールバックし警告を出力します
TIDB_SSL_CA=

# App
APP_ENV=development

# Rate limit (1日あたりの最大トークン数)
DAILY_TOKEN_LIMIT=10000

# Supabase
SUPABASE_URL=
SUPABASE_SECRET=

# Dify Chat API
DIFY_API_BASE_URL=
DIFY_API_KEY=

# Discord OAuth (P1: 管理画面認証)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
